{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenFrame",
  "version": "0.1.0",
  "identifier": "dev.openframe.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @openframe/desktop",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build --workspace @openframe/desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenFrame",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
